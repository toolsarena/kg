kgr:virgin_media_o2 a kg:Company ; skos:prefLabel "Virgin Media O2" ; rdfs:comment "Joint venture of Liberty Global and Telefonica. Cable broadband and mobile." ; kg:industry kgr:ind_telecom ; kg:incorporated_in kgr:jurisdiction_uk .
kgr:three_uk a kg:Company ; skos:prefLabel "Three UK" ; rdfs:comment "Mobile network operator owned by CK Hutchison" ; kg:industry kgr:ind_telecom ; kg:incorporated_in kgr:jurisdiction_uk .
kgr:o2 a kg:Company ; skos:prefLabel "O2 (Telefonica UK)" ; rdfs:comment "Mobile network, now part of Virgin Media O2" ; kg:industry kgr:ind_telecom ; kg:subsidiary_of kgr:virgin_media_o2 .
kgr:zen_internet a kg:Company ; skos:prefLabel "Zen Internet" ; rdfs:comment "UK ISP focused on quality and customer service" ; kg:industry kgr:ind_telecom ; kg:incorporated_in kgr:jurisdiction_uk .
kgr:cityfibre a kg:Company ; skos:prefLabel "CityFibre" ; rdfs:comment "Alternative full fibre network builder, competitor to Openreach" ; kg:industry kgr:ind_telecom ; kg:incorporated_in kgr:jurisdiction_uk .

kgr:bt_group kg:competes_with kgr:vodafone .
kgr:bt_group kg:competes_with kgr:sky .
kgr:bt_group kg:competes_with kgr:virgin_media_o2 .
kgr:openreach kg:competes_with kgr:cityfibre .

