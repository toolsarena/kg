kgr:microsoft a kg:Company ; skos:prefLabel "Microsoft" ; rdfs:comment "Cloud and productivity partner (Azure, Teams)" ; kg:industry kgr:ind_cloud .
kgr:cisco a kg:Company ; skos:prefLabel "Cisco" ; rdfs:comment "Networking equipment and SD-WAN partner" ; kg:industry kgr:ind_networking .
kgr:nokia a kg:Company ; skos:prefLabel "Nokia" ; rdfs:comment "5G network equipment supplier" ; kg:industry kgr:ind_telecom .
