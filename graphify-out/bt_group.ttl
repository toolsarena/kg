# ============================================================
# REGULATORS
# ============================================================
kgr:ofcom a kg:Regulator ; skos:prefLabel "Ofcom" ; rdfs:comment "UK communications regulator" .
kgr:fca a kg:Regulator ; skos:prefLabel "Financial Conduct Authority" ; rdfs:comment "UK financial regulator (BT is listed on LSE)" .
kgr:ico a kg:Regulator ; skos:prefLabel "Information Commissioner's Office" ; rdfs:comment "UK data protection regulator" .
kgr:bt_group kg:regulated_by kgr:ico .

# ============================================================
# JURISDICTIONS
# ============================================================
kgr:jurisdiction_uk a kg:Jurisdiction ; skos:prefLabel "United Kingdom" .
kgr:jurisdiction_us a kg:Jurisdiction ; skos:prefLabel "United States" .
kgr:jurisdiction_eu a kg:Jurisdiction ; skos:prefLabel "European Union" .
kgr:jurisdiction_apac a kg:Jurisdiction ; skos:prefLabel "Asia Pacific" .

# ============================================================
# INDUSTRIES
# ============================================================
kgr:ind_telecom a kg:Industry ; skos:prefLabel "Telecommunications" .
kgr:ind_it_services a kg:Industry ; skos:prefLabel "IT Services" .
kgr:ind_cloud a kg:Industry ; skos:prefLabel "Cloud Computing" .
kgr:ind_networking a kg:Industry ; skos:prefLabel "Networking Equipment" .
kgr:ind_security a kg:Industry ; skos:prefLabel "Cybersecurity" .

# ============================================================
# KEY FILINGS / EVENTS
# ============================================================
kgr:filing_annual_2024 a kg:Filing ; skos:prefLabel "Annual Report 2024" ; rdfs:comment "BT Group Annual Report and Form 20-F 2024" ; dcterms:source "Companies House" .
kgr:filing_ee_acquisition a kg:Filing ; skos:prefLabel "EE Acquisition (2016)" ; rdfs:comment "BT acquired EE for £12.5 billion, creating UK's largest mobile operator" .
kgr:filing_openreach_separation a kg:Filing ; skos:prefLabel "Openreach Legal Separation (2018)" ; rdfs:comment "Ofcom required legal separation of Openreach from BT Group" .
kgr:filing_fttp_target a kg:Filing ; skos:prefLabel "FTTP 25m Target (2026)" ; rdfs:comment "BT/Openreach target to reach 25 million premises with full fibre by Dec 2026" .
kgr:filing_pstn_switch_off a kg:Filing ; skos:prefLabel "PSTN Switch-Off (2027)" ; rdfs:comment "BT switching off legacy copper PSTN network by 2027, moving all to digital" .
kgr:filing_tnt_rebrand a kg:Filing ; skos:prefLabel "BT Sport → TNT Sports Rebrand (2023)" ; rdfs:comment "BT Sport rebranded to TNT Sports as part of joint venture with Warner Bros Discovery" .

kgr:bt_group kg:filed kgr:filing_annual_2024 .
kgr:bt_group kg:filed kgr:filing_ee_acquisition .
kgr:bt_group kg:filed kgr:filing_openreach_separation .
