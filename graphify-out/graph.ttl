kg:customersuggestion a owl:Class ;
    rdfs:label "Customer Suggestion" ;
    rdfs:comment "A suggestion made by a customer regarding a product or service." ;
    kg:suggestedproduct xsd:string ;
    kg:suggestedservice xsd:string .

kg:product a owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "A product offered by the organization." ;
    kg:productname xsd:string ;
    kg:productdescription xsd:string .

kg:service a owl:Class ;
    rdfs:label "Service" ;
    rdfs:comment "A service offered by the organization." ;
    kg:servicename xsd:string ;
    kg:servicedescription xsd:string .

kg:suggests a owl:ObjectProperty ;
    rdfs:label "Suggests Product" ;
    rdfs:domain kg:customersuggestion ;
    rdfs:range kg:product .

kg:suggests a owl:ObjectProperty ;
    rdfs:label "Suggests Service" ;
    rdfs:domain kg:customersuggestion ;
    rdfs:range kg:service .


