@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

kg:customer a owl:Class ;
    rdfs:label "Customer" ;
    rdfs:comment "A customer of a telecom service provider." ;
    kg:accounts xsd:string ;
    kg:paymentmethods xsd:string ;
    kg:contactmedium xsd:string .

kg:product a owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "A product offered by the telecom service provider." ;
    kg:productoffering xsd:string ;
    kg:productorder xsd:string .

kg:service a owl:Class ;
    rdfs:label "Service" ;
    rdfs:comment "A service provided to a customer." ;
    kg:serviceorder xsd:string ;
    kg:servicespecification xsd:string .

kg:resource a owl:Class ;
    rdfs:label "Resource" ;
    rdfs:comment "A physical or logical resource used in the telecom service." ;
    kg:resourcespecification xsd:string .

kg:party a owl:Class ;
    rdfs:label "Party" ;
    rdfs:comment "An individual or organization involved in the telecom service." .

kg:address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:comment "A physical address associated with a party or service." .

kg:troubleticket a owl:Class ;
    rdfs:label "Trouble Ticket" ;
    rdfs:comment "A ticket raised by a customer regarding a service issue." ;
    kg:service xsd:string .

kg:alarm a owl:Class ;
    rdfs:label "Alarm" ;
    rdfs:comment "An alarm triggered by a resource indicating an issue." ;
    kg:resource xsd:string .

kg:hasproducts a owl:ObjectProperty ;
    rdfs:label "Has Products" ;
    rdfs:domain kg:customer ;
    rdfs:range kg:product .

kg:usesservices a owl:ObjectProperty ;
    rdfs:label "Uses Services" ;
    rdfs:domain kg:customer ;
    rdfs:range kg:service .

kg:realizedby a owl:ObjectProperty ;
    rdfs:label "Realized By" ;
    rdfs:domain kg:product ;
    rdfs:range kg:service .

kg:usesresources a owl:ObjectProperty ;
    rdfs:label "Uses Resources" ;
    rdfs:domain kg:service ;
    rdfs:range kg:resource .

kg:hasaddress a owl:ObjectProperty ;
    rdfs:label "Has Address" ;
    rdfs:domain kg:party ;
    rdfs:range kg:address .

kg:raisestroubleticket a owl:ObjectProperty ;
    rdfs:label "Raises Trouble Ticket" ;
    rdfs:domain kg:service ;
    rdfs:range kg:troubleticket .

kg:triggersalarm a owl:ObjectProperty ;
    rdfs:label "Triggers Alarm" ;
    rdfs:domain kg:resource ;
    rdfs:range kg:alarm .


