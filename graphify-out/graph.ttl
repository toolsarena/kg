@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# --- Ontology ---
kg:Concept a owl:Class ; rdfs:label "Concept" .
kg:Service a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Service" .
kg:Decision a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Architectural Decision" .
kg:Team a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Team or Owner" .
kg:Document a owl:Class ; rdfs:label "Source Document" .
kg:Community a owl:Class ; rdfs:label "Community / Cluster" .
kg:BestPractice a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Best Practice" .
kg:Pillar a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Well-Architected Pillar" .
kg:Process a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Process" .
kg:Role a owl:Class ; rdfs:subClassOf kg:Concept ; rdfs:label "Role" .

kg:depends_on a owl:ObjectProperty ; rdfs:label "depends on" .
kg:relates_to a owl:ObjectProperty ; rdfs:label "relates to" .
kg:owned_by a owl:ObjectProperty ; rdfs:label "owned by" .
kg:member_of a owl:ObjectProperty ; rdfs:label "member of community" .
kg:source_doc a owl:ObjectProperty ; rdfs:label "extracted from" .
kg:implements a owl:ObjectProperty ; rdfs:label "implements" .
kg:uses a owl:ObjectProperty ; rdfs:label "uses" .
kg:part_of a owl:ObjectProperty ; rdfs:label "part of" .
kg:recommends a owl:ObjectProperty ; rdfs:label "recommends" .
kg:mitigates a owl:ObjectProperty ; rdfs:label "mitigates" .

# --- Pillars ---
kgr:operational_excellence a kg:Pillar ; skos:prefLabel "Operational Excellence" .
kgr:security a kg:Pillar ; skos:prefLabel "Security" .
kgr:reliability a kg:Pillar ; skos:prefLabel "Reliability" .
kgr:performance_efficiency a kg:Pillar ; skos:prefLabel "Performance Efficiency" .
kgr:cost_optimization a kg:Pillar ; skos:prefLabel "Cost Optimization" .
kgr:sustainability a kg:Pillar ; skos:prefLabel "Sustainability" .

