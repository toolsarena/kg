@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix fcc: <http://kg.local/fcc#> .

# ============================================================
# FCC Broadband Providers Ontology
# Domain: US broadband service deployment data
# ============================================================

# --- Classes ---

fcc:Provider a owl:Class ;
    rdfs:label "Broadband Provider" ;
    rdfs:comment "A company that provides broadband internet service." .

fcc:HoldingCompany a owl:Class ;
    rdfs:label "Holding Company" ;
    rdfs:comment "A parent company that owns one or more broadband providers." .

fcc:ServiceOffering a owl:Class ;
    rdfs:label "Service Offering" ;
    rdfs:comment "A specific broadband service deployed in a census block with defined speeds and technology." .

fcc:Location a owl:Class ;
    rdfs:label "Location" ;
    rdfs:comment "A geographic location identified by state and census block FIPS code." .

fcc:Technology a owl:Class ;
    rdfs:label "Technology" ;
    rdfs:comment "The broadband delivery technology (e.g., cable, fiber, DSL, satellite)." .

# --- Datatype Properties ---

fcc:providerID a owl:DatatypeProperty ;
    rdfs:label "Provider ID" ;
    rdfs:domain fcc:Provider ;
    rdfs:range xsd:string ;
    rdfs:comment "FCC-assigned unique provider identifier." .

fcc:frn a owl:DatatypeProperty ;
    rdfs:label "FRN" ;
    rdfs:domain fcc:Provider ;
    rdfs:range xsd:string ;
    rdfs:comment "FCC Registration Number." .

fcc:providerName a owl:DatatypeProperty ;
    rdfs:label "Provider Name" ;
    rdfs:domain fcc:Provider ;
    rdfs:range xsd:string .

fcc:dbaName a owl:DatatypeProperty ;
    rdfs:label "DBA Name" ;
    rdfs:domain fcc:Provider ;
    rdfs:range xsd:string ;
    rdfs:comment "Doing Business As name." .

fcc:holdingCompanyName a owl:DatatypeProperty ;
    rdfs:label "Holding Company Name" ;
    rdfs:domain fcc:HoldingCompany ;
    rdfs:range xsd:string .

fcc:holdingCompanyNumber a owl:DatatypeProperty ;
    rdfs:label "Holding Company Number" ;
    rdfs:domain fcc:HoldingCompany ;
    rdfs:range xsd:string .

fcc:state a owl:DatatypeProperty ;
    rdfs:label "State" ;
    rdfs:domain fcc:Location ;
    rdfs:range xsd:string .

fcc:censusBlockFIPS a owl:DatatypeProperty ;
    rdfs:label "Census Block FIPS Code" ;
    rdfs:domain fcc:Location ;
    rdfs:range xsd:string ;
    rdfs:comment "15-digit FIPS code identifying the census block." .

fcc:technologyCode a owl:DatatypeProperty ;
    rdfs:label "Technology Code" ;
    rdfs:domain fcc:Technology ;
    rdfs:range xsd:string ;
    rdfs:comment "FCC technology code (10=DSL, 40=Cable, 50=Fiber, 60=Satellite, etc.)." .

fcc:maxDownstream a owl:DatatypeProperty ;
    rdfs:label "Max Advertised Downstream Speed (mbps)" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range xsd:float .

fcc:maxUpstream a owl:DatatypeProperty ;
    rdfs:label "Max Advertised Upstream Speed (mbps)" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range xsd:float .

fcc:servesConsumer a owl:DatatypeProperty ;
    rdfs:label "Consumer" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether this offering serves residential consumers." .

fcc:servesBusiness a owl:DatatypeProperty ;
    rdfs:label "Business" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether this offering serves business customers." .

# --- Object Properties ---

fcc:ownedBy a owl:ObjectProperty ;
    rdfs:label "Owned By" ;
    rdfs:domain fcc:Provider ;
    rdfs:range fcc:HoldingCompany ;
    rdfs:comment "The holding company that owns this provider." .

fcc:offeredBy a owl:ObjectProperty ;
    rdfs:label "Offered By" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range fcc:Provider ;
    rdfs:comment "The provider offering this service." .

fcc:locatedIn a owl:ObjectProperty ;
    rdfs:label "Located In" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range fcc:Location ;
    rdfs:comment "The geographic location where this service is available." .

fcc:usesTechnology a owl:ObjectProperty ;
    rdfs:label "Uses Technology" ;
    rdfs:domain fcc:ServiceOffering ;
    rdfs:range fcc:Technology ;
    rdfs:comment "The delivery technology used for this service offering." .
